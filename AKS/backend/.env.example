# AI Assistant Configuration
# Options for AI_PROVIDER: "gemini" (production) or "mock" (offline testing fallback)
AI_PROVIDER="mock"

# If using "gemini", enter your actual Gemini API key below:
AI_API_KEY=""

# SMTP Mail Server Configuration
# If left empty, the platform falls back to the system's native PHP mail() service.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="your-email@gmail.com"
SMTP_FROM_NAME="Compliance Audit Platform"
